  <JScript><![CDATA[function T_2_macro() {

    this.save_file_path;
    this.save_file_name;
    this.today_str;
    this.latest_report_path;
    this.reportgood;
    this.mcr_reset;
    this.mcr_security;
    this.officeoff;

    this.RPAGOTOENABLE = false;
    this.GotoStepRetryCntMap = {};
    this.GotoBlockMap = {4:[6],8:[18,20],11:[14],15:[17]};
    this.GotoReverseBlockMap = {6:4,18:8,20:8,14:11,17:15};
    this.GotoStepBlockTypeMap = {4:'DecisionThen',6:'EndDecisionThen',8:'Decision',18:'Else',20:'EndDecision',11:'DecisionThen',14:'EndDecisionThen',15:'DecisionThen',17:'EndDecisionThen'};


    this.run = function() {

        //------------------------------------------------
        STEP('S1684f8361913481d869ef775e78ae6bf', '[1] ExecuteCmd');
        this.latest_report_path = SystemLib.ExecuteCmd('powershell.exe', '-NoProfile -Command "$p = Get-ChildItem \'C:\\Users\\3class_007\\Downloads\' -Filter \'*report*.xlsm\' | Sort-Object LastWriteTime -Descending | Select-Object -First 1 -ExpandProperty FullName; [Console]::Write($p)"', false, 10000, true);

        //------------------------------------------------
        STEP('Saaa675c2aeac403d861f73a25c98d26d', '[2] OpenExcel');
        RESULT = StepPlayer.Run('Excel.OpenExcel', this.openexcel_info_2);

        //------------------------------------------------
        STEP('S2e06fab818254c398fa1f2e33e0ee4f6', '[3] WaitAppear');
        try{
            this.officeoff = StepPlayer.Run('Win.WaitAppear', this.waitappear_info_3);
        }catch(e){
            Warn('CatchException: ' + e.message);
        }


        //------------------------------------------------
        STEP('S95e2481d3260496db11fd2c4a45ed34a', '[4] IfThen');
        if (this.officeoff == true) {

            //------------------------------------------------
            STEP('S90c4a9ec98a3404a9f397e8ba499ceea', '[5] Click');
            StepPlayer.Run('Win.Click', this.click_info_5);

        //------------------------------------------------
        }
        STEP('S5f764c4723b54dd58b9e7c0894c37764', '[6] End-IfThen');

        //------------------------------------------------
        STEP('S26d9b2af7c514b898fa6d7c77318aa0b', '[7] WaitAppear');
        try{
            this.mcr_security = StepPlayer.Run('Win.WaitAppear', this.waitappear_info_7);
        }catch(e){
            Warn('CatchException: ' + e.message);
        }


        //------------------------------------------------
        STEP('Sc9fb38daaa4f490ba6e4da2abf0a0477', '[8] IfElse');
        if (this.mcr_security == true) {

            //------------------------------------------------
            STEP('S5622ccc2298741c5be7146cf120e8321', '[9] Click');
            StepPlayer.Run('Win.Click', this.click_info_9);

            //------------------------------------------------
            STEP('S3be24f4a377a496db7a09f8b76927b06', '[10] WaitAppear');
            try{
                this.mcr_reset = StepPlayer.Run('Win.WaitAppear', this.waitappear_info_10);
            }catch(e){
                Warn('CatchException: ' + e.message);
            }


            //------------------------------------------------
            STEP('S19a26348c19c4a2cb2de0dcdc722d5a6', '[11] IfThen');
            if (this.mcr_reset == true) {

                //------------------------------------------------
                STEP('S9dec677c65134a1dbae42d9c2aabd663', '[12] Click');
                StepPlayer.Run('Win.Click', this.click_info_12);

                //------------------------------------------------
                STEP('S5b6a15a9ec944c98b3116b537f7cfdc0', '[13] WaitAppear');
                try{
                    this.reportgood = StepPlayer.Run('Win.WaitAppear', this.waitappear_info_13);
                }catch(e){
                    Warn('CatchException: ' + e.message);
                }


            //------------------------------------------------
            }
            STEP('S8b9d4971b8c743c19493472065920a23', '[14] End-IfThen');

            //------------------------------------------------
            STEP('Sb7fec3411e46476780cb670eea4f5598', '[15] IfThen');
            if (this.reportgood == true) {

                //------------------------------------------------
                STEP('S682fbe819da04cedad728d093959d224', '[16] Click');
                StepPlayer.Run('Win.Click', this.click_info_16);

            //------------------------------------------------
            }
            STEP('Sba60148ab91342aab70bc55dcdef94e3', '[17] End-IfThen');

        //------------------------------------------------
        }else{
            STEP('S7e17e3a07ae943c483e55511399bfe72', '[18] Else');

            //------------------------------------------------
            STEP('Sa762b467c1bd4598b4ffdb64d3359b06', '[19] ExecuteMacro');
            StepPlayer.Run('Excel.ExecuteMacro', this.executemacro_info_19);

        //------------------------------------------------
        }
        STEP('S7585b873b56b4777ba1e112aa21383d6', '[20] End-IfElse');

        //------------------------------------------------
        STEP('S93225445689e4658bd3937a2af8c2eee', '[21] ExecuteScript');
        var now = new Date();
        var yyyy = now.getFullYear().toString();
        var mm = ('0' + (now.getMonth() + 1)).slice(-2);
        var dd = ('0' + now.getDate()).slice(-2);

        this.today_str = yyyy + '-' + mm + '-' + dd;
        this.save_file_name = this.today_str + '_report.xlsm';
        this.save_file_path = 'C:\\Users\\3class_007\\Downloads\\' + this.save_file_name;

        //------------------------------------------------
        STEP('Sf64cf8db362b44818c80ab31dee6086b', '[22] SaveExcel');
        StepPlayer.Run('Excel.SaveExcel', this.saveexcel_info_22);

        //------------------------------------------------
        STEP('S075b5ca974f64c1db63eaa7f4096d245', '[23] CloseExcel');
        StepPlayer.Run('Excel.CloseExcel', this.closeexcel_info_23);


    }

    this.execute = function() {
        var result = null;
        result = this.run()
        if (result != null)
            return result;
        return {'save_file_path':this.save_file_path, 'save_file_name':this.save_file_name, 'today_str':this.today_str};
    }
}
]]></JScript>
