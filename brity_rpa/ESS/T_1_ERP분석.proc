  <JScript><![CDATA[function T_1_ERP분석() {

    this.dontsave;
    this.mypw;
    this.myid;
    this.anal_check;

    this.RPAGOTOENABLE = false;
    this.GotoStepRetryCntMap = {};
    this.GotoBlockMap = {7:[9],13:[15]};
    this.GotoReverseBlockMap = {9:7,15:13};
    this.GotoStepBlockTypeMap = {7:'DecisionThen',9:'EndDecisionThen',13:'DecisionThen',15:'EndDecisionThen'};


    this.run = function() {

        //------------------------------------------------
        STEP('S43f2ae63ed7d4449b07d72055a5c5c29', '[1] InputBox');
        this.myid = InputBox('','Text', 'ERP ID를 입력해주세요', 600);

        //------------------------------------------------
        STEP('S482787b8f7ae468287bb1edfaee1af48', '[2] InputBox');
        this.mypw = InputBox('','Text', 'ERP PW를 입력해주세요', 600);

        //------------------------------------------------
        STEP('Se302109d2a6040bfb826b931ae68c58c', '[3] ChromeOpen');
        RESULT = StepPlayer.Run('Chrome.ChromeOpen', this.chromeopen_info_3);

        //------------------------------------------------
        STEP('S9d9e752e39864fa383fa25a44a3f24b9', '[4] TextInput');
        StepPlayer.Run('Win.TextInput', this.textinput_info_4);

        //------------------------------------------------
        STEP('S739fab99b6e842ee9f5535c873c0b55b', '[5] TextInput');
        StepPlayer.Run('Win.TextInput', this.textinput_info_5);

        //------------------------------------------------
        STEP('S8e2df62b267a4f9dbcb48320dc879849', '[6] WaitAppear');
        try{
            this.dontsave = StepPlayer.Run('Win.WaitAppear', this.waitappear_info_6);
        }catch(e){
            Warn('CatchException: ' + e.message);
        }


        //------------------------------------------------
        STEP('S8e94a06c41ad47e49b53da2c4372fe2a', '[7] IfThen');
        if (this.dontsave == true) {

            //------------------------------------------------
            STEP('S5484d476af3f416caed647f9c98008bf', '[8] Click');
            StepPlayer.Run('Win.Click', this.click_info_8);

        //------------------------------------------------
        }
        STEP('S4d42a3f3db7f4cca8b96229135adf793', '[9] End-IfThen');

        //------------------------------------------------
        STEP('S88968a1b2cfe45f6924790fa6ae6aa7e', '[10] Click');
        StepPlayer.Run('Win.Click', this.click_info_10);

        //------------------------------------------------
        STEP('Se5fb2a93a42b45818a4fb5e40eb3a921', '[11] Click');
        StepPlayer.Run('Win.Click', this.click_info_11);

        //------------------------------------------------
        STEP('Sc1c2994411e84a619febaa2c4d673a34', '[12] WaitAppear');
        try{
            this.anal_check = StepPlayer.Run('Win.WaitAppear', this.waitappear_info_12);
        }catch(e){
            Warn('CatchException: ' + e.message);
        }


        //------------------------------------------------
        STEP('S50cefdb772d747f6b495ba13ffb98b62', '[13] IfThen');
        if (this.anal_check == true) {

            //------------------------------------------------
            STEP('S139246cb23974b49a6bd0113782acccd', '[14] Click');
            StepPlayer.Run('Win.Click', this.click_info_14);

        //------------------------------------------------
        }
        STEP('S83706ced4e1e427793cd94d75efb2c75', '[15] End-IfThen');

        //------------------------------------------------
        STEP('Sb759c5e0f80946a38ccde18a6c84bb72', '[16] Click');
        StepPlayer.Run('Win.Click', this.click_info_16);

        //------------------------------------------------
        STEP('Sba949b982b9646e89dadb86b2a42bf61', '[17] Delay');
        Delay(3000);


    }

    this.execute = function() {
        var result = null;
        result = this.run()
        if (result != null)
            return result;
    }
}
]]></JScript>
