  <JScript><![CDATA[function T_3_SMTP(args) {

    this.str_Body;
    this.str_AttachFilePath;
    this.str_Subject;
    this.str_CC;
    this.str_Receivers;
    this.str_Sender;
    this.str_Password;
    this.str_Id;
    this.save_file_path = (typeof args != 'undefined') ? args.save_file_path : null;
    this.save_file_name = (typeof args != 'undefined') ? args.save_file_name : null;
    this.today_str = (typeof args != 'undefined') ? args.today_str : null;

    this.RPAGOTOENABLE = false;
    this.GotoStepRetryCntMap = {};
    this.GotoBlockMap = {};
    this.GotoReverseBlockMap = {};
    this.GotoStepBlockTypeMap = {};


    this.run = function() {

        //------------------------------------------------
        STEP('S5cd5504cc6964f0692b67748e0403467', '[1] ExecuteScript');
        // 메일 기본 정보
        // ID값
        this.str_Id = 'xpbpq9981'
        // 앱 비밀번호
        this.str_Password = 'sqcl mrqo hmhr kper'
        // 발신자(보내는 사람 메일 주소)
        this.str_Sender = 'xpbpq9981@gmail.com'
        // 수신자(받는사람 메일 주소)
        this.str_Receivers = 'rlarkdtks14@naver.com'
        // 참조자
        this.str_CC = 'swngmls3571@naver.com'

        // 메일 제목/본문에 사용할 날짜 문자열
        this.today_full = this.today_str;

        // 메일 제목
        this.str_Subject = 'ESS 경영 분석 보고서_' + this.today_full;

        // 수신자 메일에서 @ 앞부분 추출
        var receiverName = this.str_Receivers.split("@")[0];

        // 메일 내용
        this.str_Body =
            receiverName + "님 안녕하세요.\n\n" +
            this.today_full + " 기준 ESS 경영 분석 보고서 엑셀 파일 전달드립니다.\n" +
            "첨부파일명: " + this.save_file_name + "\n\n감사합니다.";

        // 첨부파일 경로 저장
        this.str_AttachFilePath = this.save_file_path;

        // 최종 파일 존재 여부 체크
        if (!this.str_AttachFilePath || this.str_AttachFilePath === "") {
            throw "첨부파일 경로가 비어 있습니다.";
        }

        if (!System.IO.File.Exists(this.str_AttachFilePath)) {
            throw "첨부파일이 존재하지 않습니다: " + this.str_AttachFilePath;
        }

        //------------------------------------------------
        STEP('S219319c22bbb47f685a99a92d6a12fed', '[2] SendMail');
        StepPlayer.Run('Net.SendMail', this.sendmail_info_2);


    }

    this.execute = function() {
        var result = null;
        result = this.run()
        if (result != null)
            return result;
    }
}
]]></JScript>
