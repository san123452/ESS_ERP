<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.ess.erp.mapper.EmployeeMapper">

    <!-- 사원 목록 조회 -->
    <select id="selectEmpList" 
            resultType="com.ess.erp.domain.EmployeeDTO">
        SELECT 
            EMP_ID    AS empId,
            EMP_NM    AS empName,
            DEPT_CD   AS deptCode,
            POSITION  AS position,
            USE_YN    AS useYn,
            REG_DT    AS regDt
        FROM TB_EMP
        WHERE USE_YN = 'Y'
        ORDER BY EMP_ID
    </select>

</mapper>